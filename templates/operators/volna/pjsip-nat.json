{
  "id": "volna-pjsip-nat",
  "name": "Volna PJSIP NAT",
  "operator": "Волна",
  "region": "Крым",
  "country": "RU",
  "technology": "pjsip",
  "status": "draft",
  "testedWith": { "freepbx": [], "asterisk": [], "notes": "NAT-focused baseline; confirm network path and RTP." },
  "fields": {
    "transport": "udp",
    "sipServer": "sip.volna.example",
    "sipServerPort": 5060,
    "username": "${LOCAL_LOGIN}",
    "authUsername": "${LOCAL_LOGIN}",
    "passwordPlaceholder": "Введите SIP-пароль локально",
    "authentication": "outbound",
    "registration": "send",
    "context": "from-trunk",
    "match": "sip.volna.example",
    "dtmfMode": "rfc4733",
    "directMedia": "no",
    "rewriteContact": "yes",
    "rtpSymmetric": "yes",
    "forceRport": "yes",
    "qualifyFrequency": 60,
    "codecs": ["alaw", "ulaw"],
    "mediaEncryption": "no",
    "timers": "yes"
  },
  "requiredUserFields": ["username", "passwordPlaceholder", "authUsername"],
  "numberFormats": { "outbound": ["E.164", "local"], "inbound": ["DID from operator"] },
  "diagnostics": { "hints": ["Проверить внешний адрес FreePBX, RTP range и SIP ALG.", "Direct Media должен быть выключен для NAT."], "commonErrors": ["one-way audio", "no audio", "registration timeout"] },
  "notes": ["Используйте как отправную точку для АТС за NAT."],
  "security": { "containsSecrets": false, "secretPolicy": "Passwords are local-only and never stored in Git." },
  "migration": { "canMigrateToPjsip": false, "isMigrationTarget": true, "mappingProfile": "default-chansip-to-pjsip" }
}
