# DB connection parameters for FreePBX / Asterisk MariaDB (Read-Only)
FREEPBX_DB_HOST="localhost"
FREEPBX_DB_PORT="3306"
FREEPBX_DB_NAME="asteriskcdrdb"
FREEPBX_DB_USER="cdrviewer"
FREEPBX_DB_PASSWORD="your_secure_password"

# Path to Asterisk audio recordings (e.g., location of monitor files)
# Typical values in CentOS-based systems: /var/spool/asterisk/monitor
RECORDINGS_PATH="/var/spool/asterisk/monitor"

# Optional: prefix URL for playing recordings directly if proxied or hosted
RECORDINGS_URL_PREFIX=""

# Demo mode (enables simulation when actual FreePBX/Asterisk DB is unavailable)
# Set to 'true' to show realistic simulated data in the AI Studio preview environment
DEMO_MODE="false"

# Service credentials for secure web access (Express/SQLite)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin_secure_password"

OPERATOR_USERNAME="operator"
OPERATOR_PASSWORD="operator_secure_password"

# Server Port
PORT="3000"

# Asterisk AMI settings for Click-To-Call
ASTERISK_AMI_HOST="127.0.0.1"
ASTERISK_AMI_PORT="5038"
ASTERISK_AMI_USER="999"
ASTERISK_AMI_PASSWORD="YOUR_AMI_PASSWORD"
ASTERISK_AMI_CONTEXT="from-internal"

# Gemini API Key for Server-Side AI Processing
GEMINI_API_KEY=""

# Additional LLM Keys for AI Admin (ChatGPT, Claude, DeepSeek)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""
# PBXPuls internal database (separate from asterisk/asteriskcdrdb)
PBXPULS_DB_HOST=127.0.0.1
PBXPULS_DB_PORT=3306
PBXPULS_DB_NAME=pbxpuls
PBXPULS_DB_USER=pbxpuls
PBXPULS_DB_PASSWORD=
# 32-byte key as 64 hex characters or Base64. Required only for encrypted AI callback requests.
PBXPULS_AI_ACTION_ENCRYPTION_KEY=
# Optional separate HMAC key for tenant-scoped phone hashes.
PBXPULS_AI_ACTION_HASH_KEY=
