import React, { useEffect, useMemo, useState } from 'react';
import {
  Activity,
  AlertTriangle,
  CheckCircle2,
  Cpu,
  Database,
  Gauge,
  Globe2,
  HardDrive,
  Network,
  RefreshCw,
  Server,
  ShieldCheck,
  Wifi
} from 'lucide-react';

type HealthReportTabProps = {
  token: string;
};

type HealthReport = {
  success: boolean;
  generatedAt: string;
  score: number;
  status: string;
  summary?: any;
  system?: any;
  disks?: any[];
  inodes?: any[];
  network?: any;
  internet?: any;
  services?: any[];
  asterisk?: any;
  error?: string;
};

type HealthHistoryPoint = {
  timestamp: string;
  bootId?: string;
  uptimeSeconds?: number;
  load1?: number;
  load5?: number;
  load15?: number;
  cpuPercent?: number | null;
  memoryPercent?: number;
  swapPercent?: number;
  diskRootPercent?: number;
  internet?: {
    googleAvgMs?: number | null;
    googleLoss?: number;
    yandexAvgMs?: number | null;
    yandexLoss?: number;
  };
  network?: {
    iface?: string;
    rxKbps?: number;
    txKbps?: number;
  };
  asterisk?: {
    activeChannels?: number;
    activeCalls?: number;
  };
};

const statusColor = (ok: boolean) =>
  ok
    ? 'text-emerald-700 bg-emerald-50 border-emerald-200 dark:text-emerald-300 dark:bg-emerald-950/30 dark:border-emerald-900'
    : 'text-rose-700 bg-rose-50 border-rose-200 dark:text-rose-300 dark:bg-rose-950/30 dark:border-rose-900';

const percentColor = (value: number) => {
  if (value >= 90) return 'text-rose-600';
  if (value >= 80) return 'text-amber-600';
  return 'text-emerald-600';
};

const Card = ({ title, icon, children }: { title: string; icon: React.ReactNode; children: React.ReactNode }) => (
  <div className="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-4 shadow-sm">
    <div className="flex items-center gap-2 mb-3">
      <div className="p-2 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300">
        {icon}
      </div>
      <div className="text-sm font-black text-slate-900 dark:text-white">{title}</div>
    </div>
    {children}
  </div>
);

const MiniHealthChart = ({
  data,
  series,
  height = 210,
  maxY
}: {
  data: any[];
  series: { key: string; label: string; suffix?: string; displayKey?: string }[];
  height?: number;
  maxY?: number;
}) => {
  const width = 760;
  const pad = { left: 38, right: 18, top: 16, bottom: 28 };
  const chartW = width - pad.left - pad.right;
  const chartH = height - pad.top - pad.bottom;

  const [hoverIndex, setHoverIndex] = React.useState<number | null>(null);

  const values = data.flatMap(row => series.map(s => Number(row[s.key] ?? 0))).filter(v => Number.isFinite(v));
  const yMax = Math.max(maxY || 0, ...values, 1);
  const yMin = 0;

  const pointsFor = (key: string) => data.map((row, idx) => {
    const x = pad.left + (idx / Math.max(1, data.length - 1)) * chartW;
    const raw = Number(row[key] ?? 0);
    const val = Math.max(yMin, Math.min(yMax, Number.isFinite(raw) ? raw : 0));
    const y = pad.top + chartH - ((val - yMin) / Math.max(1, yMax - yMin)) * chartH;
    return { x, y, val };
  });

  const pathFor = (key: string) => pointsFor(key).map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' ');

  if (!data.length) {
    return (
      <div className="h-52 flex items-center justify-center text-xs font-bold text-slate-400 bg-slate-50 dark:bg-slate-800/50 rounded-xl">
        История ещё накапливается. Подождите 2–3 минуты.
      </div>
    );
  }

  const first = data[0];
  const last = data[data.length - 1];
  const hovered = hoverIndex !== null ? data[hoverIndex] : null;
  const hoverX = hoverIndex !== null
    ? pad.left + (hoverIndex / Math.max(1, data.length - 1)) * chartW
    : 0;

  const handleMove = (e: React.MouseEvent<SVGSVGElement>) => {
    const rect = e.currentTarget.getBoundingClientRect();
    const ratio = Math.max(0, Math.min(1, (e.clientX - rect.left) / Math.max(1, rect.width)));
    const idx = Math.round(ratio * Math.max(0, data.length - 1));
    setHoverIndex(idx);
  };

  return (
    <div>
      <div className="relative h-56 w-full overflow-hidden rounded-xl bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-700">
        <svg
          viewBox={`0 0 ${width} ${height}`}
          className="w-full h-full cursor-crosshair"
          onMouseMove={handleMove}
          onMouseLeave={() => setHoverIndex(null)}
        >
          <line x1={pad.left} y1={pad.top} x2={pad.left} y2={height - pad.bottom} stroke="currentColor" className="text-slate-200 dark:text-slate-700" />
          <line x1={pad.left} y1={height - pad.bottom} x2={width - pad.right} y2={height - pad.bottom} stroke="currentColor" className="text-slate-200 dark:text-slate-700" />

          {[0.25, 0.5, 0.75].map(k => (
            <line key={k} x1={pad.left} x2={width - pad.right} y1={pad.top + chartH * k} y2={pad.top + chartH * k} stroke="currentColor" className="text-slate-100 dark:text-slate-700/70" strokeDasharray="4 4" />
          ))}

          {series.map((sItem, idx) => (
            <path
              key={sItem.key}
              d={pathFor(sItem.key)}
              fill="none"
              stroke="currentColor"
              strokeWidth={idx === 0 ? 3 : 2}
              className={idx === 0 ? 'text-emerald-500' : idx === 1 ? 'text-blue-500' : idx === 2 ? 'text-amber-500' : 'text-rose-500'}
            />
          ))}

          {data.map((row, idx) => {
            if (idx % Math.ceil(Math.max(1, data.length / 6)) !== 0 && idx !== data.length - 1) return null;
            const x = pad.left + (idx / Math.max(1, data.length - 1)) * chartW;
            const label = new Date(row.timestamp).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit', hour12: false });
            return (
              <text key={idx} x={x} y={height - 8} textAnchor="middle" fontSize="10" fill="currentColor" className="text-slate-400">
                {label}
              </text>
            );
          })}

          {hovered && (
            <>
              <line
                x1={hoverX}
                x2={hoverX}
                y1={pad.top}
                y2={height - pad.bottom}
                stroke="currentColor"
                strokeWidth="1.5"
                className="text-slate-400 dark:text-slate-300"
                strokeDasharray="4 4"
              />

              {series.map((sItem, idx) => {
                const p = pointsFor(sItem.key)[hoverIndex || 0];
                if (!p) return null;
                return (
                  <circle
                    key={sItem.key}
                    cx={p.x}
                    cy={p.y}
                    r={4}
                    fill="currentColor"
                    className={idx === 0 ? 'text-emerald-500' : idx === 1 ? 'text-blue-500' : idx === 2 ? 'text-amber-500' : 'text-rose-500'}
                  />
                );
              })}
            </>
          )}
        </svg>

        {hovered && (
          <div
            className="absolute top-3 z-20 min-w-[170px] rounded-xl border border-slate-200 dark:border-slate-700 bg-white/95 dark:bg-slate-950/95 shadow-lg p-3 text-[11px]"
            style={{
              left: hoverX > width * 0.65 ? 'auto' : Math.max(8, (hoverX / width) * 100) + '%',
              right: hoverX > width * 0.65 ? Math.max(8, ((width - hoverX) / width) * 100) + '%' : 'auto'
            }}
          >
            <div className="font-black text-slate-900 dark:text-white mb-1">
              {new Date(hovered.timestamp).toLocaleString('ru-RU', { hour12: false })}
            </div>
            <div className="space-y-1">
              {series.map((sItem, idx) => {
                const val = Number(hovered[sItem.displayKey || sItem.key] ?? 0);
                return (
                  <div key={sItem.key} className="flex items-center justify-between gap-4">
                    <span className={idx === 0 ? 'text-emerald-600' : idx === 1 ? 'text-blue-600' : idx === 2 ? 'text-amber-600' : 'text-rose-600'}>
                      {sItem.label}
                    </span>
                    <span className="font-black text-slate-800 dark:text-slate-100">
                      {Number.isFinite(val) ? val : 0}{sItem.suffix || ''}
                    </span>
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </div>

      <div className="mt-2 flex flex-wrap gap-3 text-[11px] font-bold text-slate-500">
        {series.map((sItem, idx) => {
          const lastVal = Number(last?.[sItem.displayKey || sItem.key] ?? 0);
          return (
            <span key={sItem.key} className={idx === 0 ? 'text-emerald-600' : idx === 1 ? 'text-blue-600' : idx === 2 ? 'text-amber-600' : 'text-rose-600'}>
              {sItem.label}: {Number.isFinite(lastVal) ? lastVal : 0}{sItem.suffix || ''}
            </span>
          );
        })}
        <span className="text-slate-400">
          период: {first ? new Date(first.timestamp).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit', hour12: false }) : '—'} — {last ? new Date(last.timestamp).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit', hour12: false }) : '—'}
        </span>
      </div>
    </div>
  );
};

const HealthReportTab: React.FC<HealthReportTabProps> = ({ token }) => {
  const [data, setData] = useState<HealthReport | null>(null);
  const [history, setHistory] = useState<HealthHistoryPoint[]>([]);
  const [historyPeriod, setHistoryPeriod] = useState<'1h' | '24h' | '7d' | '30d'>('1h');
  const [reboots, setReboots] = useState<any[]>([]);
  const [loading, setLoading] = useState(false);
  const [err, setErr] = useState('');

  const load = async () => {
    if (!token) return;
    setLoading(true);
    setErr('');
    try {
      const res = await fetch('/api/health-report', {
        headers: { Authorization: `Bearer ${token}` }
      });
      const json = await res.json();
      if (!res.ok || !json.success) {
        throw new Error(json.error || `HTTP ${res.status}`);
      }
      setData(json);

      const historyRes = await fetch(`/api/health-report/history?period=${encodeURIComponent(historyPeriod)}`, {
        headers: { Authorization: `Bearer ${token}` }
      });
      const historyJson = await historyRes.json();
      if (historyRes.ok && historyJson.success) {
        setHistory(Array.isArray(historyJson.history) ? historyJson.history : []);
        setReboots(Array.isArray(historyJson.reboots) ? historyJson.reboots : []);
      }
    } catch (e: any) {
      setErr(e.message || String(e));
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    load();
    const t = setInterval(load, 60000);
    return () => clearInterval(t);
  }, [token, historyPeriod]);

  const mainDisks = useMemo(() => {
    return (data?.disks || []).filter((d: any) =>
      ['/', '/boot', '/var', '/var/spool/asterisk/monitor'].includes(String(d.mount || ''))
    );
  }, [data]);

  const services = useMemo(() => {
    const preferred = ['asterisk', 'mariadb', 'httpd', 'fail2ban', 'crond'];
    return (data?.services || []).filter((s: any) => preferred.includes(String(s.name)));
  }, [data]);

  const chartRows = useMemo(() => {
    return history.map((p: HealthHistoryPoint) => ({
      timestamp: p.timestamp,
      cpu: Number(p.cpuPercent || 0),
      ram: Number(p.memoryPercent || 0),
      swap: Number(p.swapPercent || 0),
      disk: Number(p.diskRootPercent || 0),
      calls: Number(p.asterisk?.activeCalls || 0) > 0
        ? Number(p.asterisk?.activeCalls || 0)
        : Math.ceil(Number(p.asterisk?.activeChannels || 0) / 2),
      callsScaled: (Number(p.asterisk?.activeCalls || 0) > 0
        ? Number(p.asterisk?.activeCalls || 0)
        : Math.ceil(Number(p.asterisk?.activeChannels || 0) / 2)) * 25,
      channels: Number(p.asterisk?.activeChannels || 0),
      googlePing: Number(p.internet?.googleAvgMs || 0),
      yandexPing: Number(p.internet?.yandexAvgMs || 0),
      rxKbps: Number(p.network?.rxKbps || 0),
      txKbps: Number(p.network?.txKbps || 0),
      uptimeHours: Math.round(Number(p.uptimeSeconds || 0) / 360) / 10
    }));
  }, [history]);

  const lastChartRow = chartRows[chartRows.length - 1] || null;
  const maxCalls = chartRows.reduce((m, r) => Math.max(m, Number(r.calls || 0)), 0);
  const maxChannels = chartRows.reduce((m, r) => Math.max(m, Number(r.channels || 0)), 0);
  const maxCpu = chartRows.reduce((m, r) => Math.max(m, Number(r.cpu || 0)), 0);
  const maxRam = chartRows.reduce((m, r) => Math.max(m, Number(r.ram || 0)), 0);

  const generated = data?.generatedAt ? new Date(data.generatedAt).toLocaleString('ru-RU', { hour12: false }) : '—';

  return (
    <div className="p-5 bg-slate-50 dark:bg-slate-950 min-h-[720px] space-y-5">
      <div className="flex flex-col xl:flex-row xl:items-center xl:justify-between gap-3">
        <div>
          <div className="flex items-center gap-2">
            <ShieldCheck className="h-5 w-5 text-emerald-600" />
            <h2 className="text-lg font-black text-slate-900 dark:text-white">Health Report / Состояние АТС</h2>
          </div>
          <p className="text-xs text-slate-500 dark:text-slate-400 mt-1">
            Железо, диски, сеть, интернет, службы, Asterisk и FreePBX. Последнее обновление: {generated}
          </p>
        </div>

        <div className="flex flex-wrap items-center gap-2">
          {(['1h', '24h', '7d', '30d'] as const).map(p => (
            <button
              key={p}
              onClick={() => setHistoryPeriod(p)}
              className={`px-3 py-2 rounded-xl text-xs font-black border ${historyPeriod === p ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : 'bg-white text-slate-600 border-slate-200 dark:bg-slate-900 dark:text-slate-300 dark:border-slate-700'}`}
            >
              {p}
            </button>
          ))}

          <button
            onClick={load}
            disabled={loading}
            className="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-xl bg-slate-900 text-white text-xs font-black disabled:opacity-60"
          >
            <RefreshCw className={`h-4 w-4 ${loading ? 'animate-spin' : ''}`} />
            Обновить
          </button>
        </div>
      </div>

      {err && (
        <div className="p-4 rounded-xl border border-rose-200 bg-rose-50 text-rose-700 text-sm font-bold">
          Ошибка загрузки Health Report: {err}
        </div>
      )}

      {!data && !err && (
        <div className="p-8 text-center text-slate-500 font-bold">
          Загрузка состояния АТС...
        </div>
      )}

      {data && (
        <>
          <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div className="md:col-span-1 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-5">
              <div className="text-xs uppercase tracking-wider font-black text-slate-400">Health Score</div>
              <div className="mt-2 flex items-end gap-2">
                <span className="text-5xl font-black text-slate-900 dark:text-white">{data.score}</span>
                <span className="text-sm font-bold text-slate-400 pb-2">/100</span>
              </div>
              <div className={`mt-4 inline-flex items-center gap-2 px-3 py-1.5 rounded-full border text-xs font-black ${data.score >= 70 ? statusColor(true) : statusColor(false)}`}>
                {data.score >= 70 ? <CheckCircle2 className="h-4 w-4" /> : <AlertTriangle className="h-4 w-4" />}
                {data.status}
              </div>
            </div>

            <Card title="CPU / Uptime" icon={<Cpu className="h-4 w-4" />}>
              <div className="text-xs text-slate-500 dark:text-slate-400 whitespace-pre-line">
                {data.system?.uptime || '—'}
              </div>
            </Card>

            <Card title="RAM / SWAP" icon={<Gauge className="h-4 w-4" />}>
              <div className="space-y-2 text-xs">
                <div className="flex justify-between">
                  <span className="text-slate-500">RAM</span>
                  <span className={`font-black ${percentColor(data.system?.memory?.usedPercent || 0)}`}>
                    {data.system?.memory?.usedPercent ?? 0}% / {data.system?.memory?.totalMb ?? 0} MB
                  </span>
                </div>
                <div className="h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                  <div className="h-full bg-current rounded-full" style={{ width: `${data.system?.memory?.usedPercent || 0}%` }} />
                </div>
                <div className="flex justify-between">
                  <span className="text-slate-500">SWAP</span>
                  <span className={`font-black ${percentColor(data.system?.swap?.usedPercent || 0)}`}>
                    {data.system?.swap?.usedPercent ?? 0}%
                  </span>
                </div>
              </div>
            </Card>

            <Card title="Интернет" icon={<Globe2 className="h-4 w-4" />}>
              <div className="space-y-1">
                {(data.internet?.ping || []).map((p: any) => (
                  <div key={p.target} className="flex items-center justify-between text-xs">
                    <span className="text-slate-500">{p.target}</span>
                    <span className={`font-black ${p.ok ? 'text-emerald-600' : 'text-rose-600'}`}>
                      {p.ok ? `${p.avgMs ?? '—'} ms` : `loss ${p.packetLoss}%`}
                    </span>
                  </div>
                ))}
              </div>
            </Card>
          </div>

          <div className="grid grid-cols-1 xl:grid-cols-2 gap-4">
            <Card title="Нагрузка железа + звонки" icon={<Cpu className="h-4 w-4" />}>
              <MiniHealthChart
                data={chartRows}
                maxY={100}
                series={[
                  { key: 'cpu', label: 'CPU', suffix: '%' },
                  { key: 'ram', label: 'RAM', suffix: '%' },
                  { key: 'callsScaled', displayKey: 'calls', label: 'Звонки' }
                ]}
              />
              <div className="mt-3 grid grid-cols-2 md:grid-cols-4 gap-2 text-[11px]">
                <div className="p-2 rounded-lg bg-slate-50 dark:bg-slate-800/60">
                  <div className="text-slate-400 font-bold">Звонки сейчас</div>
                  <div className="text-slate-900 dark:text-white font-black">{lastChartRow?.calls ?? 0}</div>
                </div>
                <div className="p-2 rounded-lg bg-slate-50 dark:bg-slate-800/60">
                  <div className="text-slate-400 font-bold">Пик звонков</div>
                  <div className="text-amber-600 font-black">{maxCalls}</div>
                </div>
                <div className="p-2 rounded-lg bg-slate-50 dark:bg-slate-800/60">
                  <div className="text-slate-400 font-bold">Пик каналов</div>
                  <div className="text-blue-600 font-black">{maxChannels}</div>
                </div>
                <div className="p-2 rounded-lg bg-slate-50 dark:bg-slate-800/60">
                  <div className="text-slate-400 font-bold">Пик CPU/RAM</div>
                  <div className="text-emerald-600 font-black">{maxCpu}% / {maxRam}%</div>
                </div>
              </div>
            </Card>

            <Card title="Интернет: Google / Yandex ping" icon={<Globe2 className="h-4 w-4" />}>
              <MiniHealthChart
                data={chartRows}
                series={[
                  { key: 'googlePing', label: 'Google', suffix: ' ms' },
                  { key: 'yandexPing', label: 'Yandex', suffix: ' ms' }
                ]}
              />
            </Card>

            <Card title="Скорость сетевого интерфейса RX / TX" icon={<Network className="h-4 w-4" />}>
              <MiniHealthChart
                data={chartRows}
                series={[
                  { key: 'rxKbps', label: 'RX', suffix: ' Kbps' },
                  { key: 'txKbps', label: 'TX', suffix: ' Kbps' }
                ]}
              />
              <div className="mt-3 text-[11px] text-slate-500">
                Первая точка после запуска всегда 0, скорость появляется со второй точки истории.
              </div>
            </Card>

            <Card title="Uptime и перезагрузки" icon={<Activity className="h-4 w-4" />}>
              <MiniHealthChart
                data={chartRows}
                series={[
                  { key: 'uptimeHours', label: 'Uptime', suffix: ' ч' }
                ]}
              />
              <div className="mt-3 text-xs font-bold text-slate-500">
                Найдено перезагрузок за период: <span className={reboots.length ? 'text-rose-600' : 'text-emerald-600'}>{reboots.length}</span>
              </div>
            </Card>
            <Card title="Диски и файловые системы" icon={<HardDrive className="h-4 w-4" />}>
              <div className="space-y-2">
                {(mainDisks.length ? mainDisks : data.disks || []).slice(0, 8).map((d: any) => (
                  <div key={`${d.filesystem}-${d.mount}`} className="p-3 rounded-xl bg-slate-50 dark:bg-slate-800/60 border border-slate-100 dark:border-slate-700">
                    <div className="flex justify-between text-xs mb-1">
                      <span className="font-black text-slate-700 dark:text-slate-200">{d.mount}</span>
                      <span className={`font-black ${percentColor(d.usedPercent)}`}>{d.usedPercent}%</span>
                    </div>
                    <div className="text-[11px] text-slate-500 mb-2">{d.filesystem} · {d.used} / {d.size} · free {d.available}</div>
                    <div className="h-2 bg-white dark:bg-slate-900 rounded-full overflow-hidden">
                      <div className="h-full bg-current rounded-full" style={{ width: `${d.usedPercent}%` }} />
                    </div>
                  </div>
                ))}
              </div>
            </Card>

            <Card title="Службы АТС" icon={<Server className="h-4 w-4" />}>
              <div className="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {services.map((s: any) => (
                  <div key={s.name} className={`p-3 rounded-xl border text-xs ${statusColor(Boolean(s.ok))}`}>
                    <div className="flex items-center justify-between">
                      <span className="font-black">{s.name}</span>
                      {s.ok ? <CheckCircle2 className="h-4 w-4" /> : <AlertTriangle className="h-4 w-4" />}
                    </div>
                    <div className="mt-1 opacity-80">{s.active}</div>
                    <div className="mt-1 opacity-60">{s.enabled}</div>
                  </div>
                ))}
              </div>
            </Card>

            <Card title="Asterisk / FreePBX" icon={<Activity className="h-4 w-4" />}>
              <div className="space-y-3 text-xs">
                <div>
                  <div className="font-black text-slate-600 dark:text-slate-300 mb-1">Версия</div>
                  <pre className="whitespace-pre-wrap text-[11px] text-slate-500 dark:text-slate-400">{data.asterisk?.version || '—'}</pre>
                </div>
                <div>
                  <div className="font-black text-slate-600 dark:text-slate-300 mb-1">Uptime</div>
                  <pre className="whitespace-pre-wrap text-[11px] text-slate-500 dark:text-slate-400">{data.asterisk?.uptime || '—'}</pre>
                </div>
                <div>
                  <div className="font-black text-slate-600 dark:text-slate-300 mb-1">Каналы</div>
