import React, { useEffect, useMemo, useState } from 'react';

type Props = {
  liveSessionsData: any;
  liveSearch: string;
  setLiveSearch: (v: string) => void;
};

function durationFmt(sec: any) {
  const s = Number(sec || 0);
  const m = Math.floor(s / 60);
  const r = s % 60;
  return String(m).padStart(2, '0') + ':' + String(r).padStart(2, '0');
}

export default function ActiveCallsTab({ liveSessionsData, liveSearch, setLiveSearch }: Props) {
  const rows = liveSessionsData?.sessions || [];

  const filtered = rows.filter((r: any) => {
    if (!liveSearch) return true;
    return JSON.stringify(r).toLowerCase().includes(liveSearch.toLowerCase());
  });

  const groups = useMemo(() => {
    const m = new Map<string, any[]>();

    filtered.forEach((r: any) => {
      const bridge = r.bridgedChannel || r.bridgedUniqueid || '__NO_BRIDGE__' + r.channel;
      if (!m.has(bridge)) m.set(bridge, []);
      m.get(bridge)!.push(r);
    });

    return Array.from(m.entries());
  }, [filtered]);

  const callCount = groups.length;

  const [history, setHistory] = useState<any[]>(() => {
    try {
      return JSON.parse(localStorage.getItem('pbxpuls_active_calls_history') || '[]');
    } catch {
      return [];
    }
  });

  useEffect(() => {
    const point = {
      time: new Date().toTimeString().split(' ')[0],
      count: callCount
    };

    const next = [...history, point].slice(-80);
    setHistory(next);
    localStorage.setItem('pbxpuls_active_calls_history', JSON.stringify(next));
  }, [callCount]);

  const max = Math.max(1, ...history.map(x => x.count));
  const points = history.map((p, i) => {
    const x = history.length <= 1 ? 0 : (i / (history.length - 1)) * 100;
    const y = 40 - (p.count / max) * 36;
    return `${x},${y}`;
  }).join(' ');

  const clickFilter = (v: any) => {
    const text = String(v || '').trim();
    if (text) setLiveSearch(text);
  };

  return (
    <div className="p-4 space-y-4">
      <div className="flex items-center justify-between gap-3">
        <div>
          <h3 className="text-sm font-black">CellTrace — активные звонки</h3>
          <div className="text-xs text-slate-500 mt-1">
            Группировка по Bridge ID. Клик по любой ячейке применяет фильтр.
          </div>
        </div>

        <div className="text-xs font-bold">
          Уникальных звонков: <span className="text-blue-700">{callCount}</span>
        </div>
      </div>

      <div className="rounded-xl border bg-white overflow-hidden">
        <table className="w-full text-[11px] font-mono">
          <thead className="bg-slate-100 text-slate-600">
            <tr>
              <th className="p-2 text-left">Channel</th>
              <th className="p-2 text-left">Context</th>
              <th className="p-2 text-left">Priority</th>
              <th className="p-2 text-left">State</th>
              <th className="p-2 text-left">App</th>
              <th className="p-2 text-left">Data</th>
              <th className="p-2 text-left">CallerID</th>
              <th className="p-2 text-left">Duration</th>
              <th className="p-2 text-left">Bridge</th>
              <th className="p-2 text-left">UniqueID</th>
            </tr>
          </thead>

          <tbody>
            {groups.map(([bridge, records]) => (
              <React.Fragment key={bridge}>
                <tr className="bg-slate-200 font-black">
                  <td colSpan={10} className="p-2">
                    Bridge ID: {bridge.startsWith('__NO_BRIDGE__') ? '[нет]' : bridge}
                  </td>
                </tr>

                {records.map((r: any, idx: number) => (
                  <tr key={idx} className="border-t hover:bg-blue-50">
                    <td onClick={() => clickFilter(r.channel)} className="p-2 cursor-pointer">{r.channel}</td>
                    <td onClick={() => clickFilter(r.context)} className="p-2 cursor-pointer">{r.context}</td>
                    <td onClick={() => clickFilter(r.priority)} className="p-2 cursor-pointer">{r.priority}</td>
                    <td onClick={() => clickFilter(r.state)} className="p-2 cursor-pointer font-black">{r.state}</td>
                    <td onClick={() => clickFilter(r.application)} className="p-2 cursor-pointer">{r.application}</td>
                    <td onClick={() => clickFilter(r.appData)} className="p-2 cursor-pointer max-w-[360px] truncate">{r.appData}</td>
                    <td onClick={() => clickFilter(r.callerId)} className="p-2 cursor-pointer">{r.callerId}</td>
                    <td className="p-2">{durationFmt(r.duration)}</td>
                    <td onClick={() => clickFilter(r.bridgedChannel)} className="p-2 cursor-pointer">{r.bridgedChannel || '—'}</td>
                    <td onClick={() => clickFilter(r.uniqueid)} className="p-2 cursor-pointer">{r.uniqueid}</td>
                  </tr>
                ))}
              </React.Fragment>
            ))}

            {groups.length === 0 && (
              <tr>
                <td colSpan={10} className="p-8 text-center text-slate-400">
                  Активных звонков сейчас нет
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>

      <div className="rounded-xl border bg-white p-3">
        <div className="text-xs font-black mb-2">График активных звонков</div>
        <svg viewBox="0 0 100 44" className="w-full h-24">
          <polyline points={points} fill="none" stroke="currentColor" strokeWidth="1.5" />
        </svg>
      </div>
    </div>
  );
}
